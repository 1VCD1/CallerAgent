# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/caller_agent

# Redis
REDIS_URL=redis://localhost:6379

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (optional — used for memory embeddings / semantic search only)
OPENAI_API_KEY=your_openai_api_key

# Firebase (optional — used for FCM push notifications to non-Expo clients)
# Paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# App
APP_BASE_URL=https://your-app.ngrok.io
WEBHOOK_BASE_URL=https://your-app.ngrok.io/webhooks
