{
  "expo": {
    "name": "CallerAgent",
    "slug": "caller-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "calleragent",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.calleragent.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020617"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#3b82f6"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
